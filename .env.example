# ─────────────────────────────────────────────────────────────────────────────
# Secrets for the Shopify blog automation edge functions.
#
# Copy to `.env` (which is gitignored) for local `supabase functions serve`,
# and/or push them to your deployed project with:
#   supabase secrets set --env-file ./.env
#
# NEVER commit real values. This file ships placeholders only.
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — keyword research, article writing, internal linking, refresh (model: gpt-4o)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Perplexity — live research + weekly topic planning (model: sonar)
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini — blog header image generation (gemini-3-pro-image-preview)
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shopify Admin API — custom app using the client_credentials grant.
# STORE_URL is just the host, no scheme: e.g. your-store.myshopify.com
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_BLOG_ID=000000000000

# Supabase — these three are injected automatically into deployed edge functions,
# so you only need them for LOCAL `supabase functions serve`.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
