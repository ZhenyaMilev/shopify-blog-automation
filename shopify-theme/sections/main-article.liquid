<script>
  (function() {
    'use strict';

    /* ===== Move the CTA banner to just before the FAQ block (fallback: stays at end of content) ===== */
    function placeCtaBeforeFaq() {
      var cta = document.getElementById('articleCtaBanner');
      var content = document.querySelector('.article-template__content');
      if (!cta || !content) return;

      /* The blog automation already injects a contextual CTA box inside the article.
         If one exists, hide our generic banner so there is only ONE call-to-action. */
      var inlineCta = content.querySelector('div[style*="0f172a"]');
      if (inlineCta) { cta.style.display = 'none'; return; }

      var faqEl = content.querySelector('.faq-section');
      if (!faqEl) {
        var firstItem = content.querySelector('.faq-item');
        if (firstItem) {
          var p = firstItem.previousElementSibling;
          while (p) { if (p.tagName === 'H2') { faqEl = p; break; } p = p.previousElementSibling; }
          if (!faqEl) faqEl = firstItem;
        }
      }
      if (!faqEl) {
        var hs = content.querySelectorAll('h2');
        for (var i = 0; i < hs.length; i++) {
          if (/frequently asked|^faq\b|\bfaqs?\b/i.test(hs[i].textContent)) { faqEl = hs[i]; break; }
        }
      }
      if (faqEl) {
        faqEl.parentNode.insertBefore(cta, faqEl);
      }
    }

    /* ===== Build the sticky table of contents from H2 headings + scroll-spy ===== */
    function initToc() {
      var content = document.querySelector('.article-template__content');
      var nav = document.getElementById('articleToc');
      var grid = document.getElementById('articleGrid');
      if (!content || !nav) return;

      var list = nav.querySelector('.article-toc__list');
      var heads = [].slice.call(content.querySelectorAll('h2')).filter(function(h) {
        return h.textContent.trim().length > 1;
      });

      if (heads.length < 2) {
        if (grid) grid.classList.add('no-toc');
        return;
      }

      var items = [];
      heads.forEach(function(h, i) {
        if (!h.id) {
          var slug = h.textContent.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 48);
          h.id = 'sec-' + (i + 1) + (slug ? '-' + slug : '');
        }
        var li = document.createElement('li');
        li.className = 'article-toc__item';
        var a = document.createElement('a');
        a.className = 'article-toc__link';
        a.href = '#' + h.id;
        a.appendChild(document.createTextNode(h.textContent.trim()));
        a.addEventListener('click', function(e) {
          e.preventDefault();
          var target = document.getElementById(h.id);
          if (target) {
            var y = target.getBoundingClientRect().top + window.pageYOffset - 96;
            window.scrollTo({ top: y, behavior: 'smooth' });
            if (history.replaceState) history.replaceState(null, '', '#' + h.id);
          }
        });
        li.appendChild(a);
        list.appendChild(li);
        items.push({ li: li, h: h });
      });

      nav.hidden = false;

      var ticking = false;
      function spy() {
        ticking = false;
        var active = 0;
        for (var i = 0; i < items.length; i++) {
          if (items[i].h.getBoundingClientRect().top <= 140) active = i; else break;
        }
        for (var j = 0; j < items.length; j++) {
          items[j].li.classList.toggle('is-active', j === active);
        }
      }
      window.addEventListener('scroll', function() {
        if (!ticking) { ticking = true; requestAnimationFrame(spy); }
      }, { passive: true });
      spy();
    }

    function initArticleFaqAccordion() {
      var contentEl = document.querySelector('.article-template__content');
      if (!contentEl) return;

      var faqData = [];

      /* ---- Pattern 1: div.faq-section with h3 + p ---- */
      var faqSections = contentEl.querySelectorAll('.faq-section');
      faqSections.forEach(function(section) {
        var heading = section.querySelector('h2');
        var headingText = heading ? heading.textContent.trim() : 'Frequently Asked Questions';

        var h3s = section.querySelectorAll('h3');
        if (h3s.length === 0) return;

        var accordionWrap = document.createElement('div');
        accordionWrap.className = 'article-faq-accordion';

        h3s.forEach(function(h3) {
          var question = h3.textContent.trim();
          var answerParts = [];
          var nextEl = h3.nextElementSibling;
          while (nextEl && nextEl.tagName !== 'H3' && nextEl.tagName !== 'H2') {
            answerParts.push(nextEl.outerHTML);
            nextEl = nextEl.nextElementSibling;
          }
          var answerHTML = answerParts.join('');
          var answerText = answerParts.map(function(h) {
            var tmp = document.createElement('div');
            tmp.innerHTML = h;
            return tmp.textContent.trim();
          }).join(' ');

          faqData.push({ question: question, answer: answerText });

          var details = document.createElement('details');
          var summary = document.createElement('summary');
          summary.innerHTML = '<span class="faq-accordion__question">' + escapeHTML(question) + '</span><span class="faq-accordion__icon" aria-hidden="true"></span>';
          var answerDiv = document.createElement('div');
          answerDiv.className = 'faq-accordion__answer';
          answerDiv.innerHTML = answerHTML;

          details.appendChild(summary);
          details.appendChild(answerDiv);
          accordionWrap.appendChild(details);
        });

        /* Replace original content: keep the heading, replace Q&A with accordion */
        var parent = section;
        /* Clear out old Q&A, keep heading */
        while (parent.firstChild) { parent.removeChild(parent.firstChild); }
        if (heading) parent.appendChild(heading);
        parent.appendChild(accordionWrap);
      });

      /* ---- Pattern 2: div.faq-item wrappers ---- */
      var faqItems = contentEl.querySelectorAll('.faq-item');
      if (faqItems.length > 0) {
        /* Find the heading before faq-items (usually h2) */
        var firstItem = faqItems[0];
        var prevSibling = firstItem.previousElementSibling;
        var faqHeading = null;
        while (prevSibling) {
          if (prevSibling.tagName === 'H2') {
            faqHeading = prevSibling;
            break;
          }
          prevSibling = prevSibling.previousElementSibling;
        }

        var accordionWrap2 = document.createElement('div');
        accordionWrap2.className = 'article-faq-accordion';

        faqItems.forEach(function(item) {
          var h3 = item.querySelector('h3');
          if (!h3) return;
          var question = h3.textContent.trim();

          /* Collect answer: everything after h3 */
          var answerParts = [];
          var nextEl = h3.nextElementSibling;
          while (nextEl) {
            answerParts.push(nextEl.outerHTML);
            nextEl = nextEl.nextElementSibling;
          }
          var answerHTML = answerParts.join('');
          var answerText = answerParts.map(function(h) {
            var tmp = document.createElement('div');
            tmp.innerHTML = h;
            return tmp.textContent.trim();
          }).join(' ');

          faqData.push({ question: question, answer: answerText });

          var details = document.createElement('details');
          var summary = document.createElement('summary');
          summary.innerHTML = '<span class="faq-accordion__question">' + escapeHTML(question) + '</span><span class="faq-accordion__icon" aria-hidden="true"></span>';
          var answerDiv = document.createElement('div');
          answerDiv.className = 'faq-accordion__answer';
          answerDiv.innerHTML = answerHTML;

          details.appendChild(summary);
          details.appendChild(answerDiv);
          accordionWrap2.appendChild(details);
        });

        /* Insert accordion after heading, remove old faq-items */
        var insertRef = faqHeading ? faqHeading.nextSibling : firstItem;
        firstItem.parentNode.insertBefore(accordionWrap2, insertRef);
        faqItems.forEach(function(item) { item.remove(); });
      }

      /* ---- Pattern 3: plain "<h2>FAQ</h2>" followed by <h3>Q</h3> + answer elements (no wrapper) ---- */
      if (faqData.length === 0) {
        var allH2 = contentEl.querySelectorAll('h2');
        var faqH2 = null;
        for (var hi = 0; hi < allH2.length; hi++) {
          var t = allH2[hi].textContent.trim();
          if (/frequently asked/i.test(t) || /^faqs?$/i.test(t) || /^faq\b/i.test(t)) { faqH2 = allH2[hi]; break; }
        }
        if (faqH2) {
          var wrap3 = document.createElement('div');
          wrap3.className = 'article-faq-accordion';
          var toRemove = [];
          var node = faqH2.nextElementSibling;
          while (node && node.tagName !== 'H2') {
            if (node.tagName === 'H3') {
              var question = node.textContent.trim();
              var parts = [];
              var ans = node.nextElementSibling;
              while (ans && ans.tagName !== 'H3' && ans.tagName !== 'H2') {
                parts.push(ans.outerHTML);
                toRemove.push(ans);
                ans = ans.nextElementSibling;
              }
              var ansHTML = parts.join('');
              var ansText = parts.map(function(h) { var d = document.createElement('div'); d.innerHTML = h; return d.textContent.trim(); }).join(' ');
              faqData.push({ question: question, answer: ansText });

              var details3 = document.createElement('details');
              var summary3 = document.createElement('summary');
              summary3.innerHTML = '<span class="faq-accordion__question">' + escapeHTML(question) + '</span><span class="faq-accordion__icon" aria-hidden="true"></span>';
              var ansDiv3 = document.createElement('div');
              ansDiv3.className = 'faq-accordion__answer';
              ansDiv3.innerHTML = ansHTML;
              details3.appendChild(summary3);
              details3.appendChild(ansDiv3);
              wrap3.appendChild(details3);

              toRemove.push(node);
              node = ans;
            } else {
              node = node.nextElementSibling;
            }
          }
          if (wrap3.children.length > 0) {
            faqH2.parentNode.insertBefore(wrap3, faqH2.nextSibling);
            toRemove.forEach(function(el) { if (el && el.parentNode) el.parentNode.removeChild(el); });
          }
        }
      }

      /* ---- Generate FAQ Schema.org structured data for SEO ---- */
      if (faqData.length > 0) {
        var schema = {
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          'mainEntity': faqData.map(function(item) {
            return {
              '@type': 'Question',
              'name': item.question,
              'acceptedAnswer': {
                '@type': 'Answer',
                'text': item.answer
              }
            };
          })
        };
        var scriptTag = document.createElement('script');
        scriptTag.type = 'application/ld+json';
        scriptTag.textContent = JSON.stringify(schema);
        document.head.appendChild(scriptTag);
      }
    }

    function escapeHTML(str) {
      var div = document.createElement('div');
      div.appendChild(document.createTextNode(str));
      return div.innerHTML;
    }

    function initArticle() {
      placeCtaBeforeFaq();
      initArticleFaqAccordion();
      initToc();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initArticle);
    } else {
      initArticle();
    }
  })();
</script>

