{% liquid assign sid = section.id %}

<section class="bcb bcb--{{ sid }}">
  <div class="bcb__inner--{{ sid }}">
    <div class="bcb__card--{{ sid }}">

      <div class="bcb__text-wrap--{{ sid }}">
        {% if section.settings.label != blank %}
          <span class="bcb__label--{{ sid }}">{{ section.settings.label }}</span>
        {% endif %}
        <p class="bcb__title--{{ sid }}">
          {{ section.settings.text }}
          {% if section.settings.bold_text != blank %}
            <strong>{{ section.settings.bold_text }}</strong>
          {% endif %}
        </p>
      </div>

      {% if section.settings.link_label != blank and section.settings.link_url != blank %}
        <a class="bcb__btn--{{ sid }}" href="{{ section.settings.link_url }}">
          <span class="bcb__btn-text--{{ sid }}">{{ section.settings.link_label }}</span>
          <span class="bcb__btn-icon--{{ sid }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </span>
        </a>
      {% endif %}

    </div>
  </div>
</section>

<style>
  .bcb--{{ sid }} {
    background: {{ section.settings.section_bg }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .bcb__inner--{{ sid }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .bcb__card--{{ sid }} {
    background: {{ section.settings.card_bg }};
    border: 1px solid {{ section.settings.card_border }};
    border-radius: 20px;
    padding: 28px 36px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .bcb__text-wrap--{{ sid }} {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .bcb__label--{{ sid }} {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    font-family: var(--font-body-family);
  }

  .bcb__title--{{ sid }} {
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 400;
    line-height: 1.3;
    color: {{ section.settings.text_color }};
    margin: 0;
    font-family: var(--font-heading-family);
  }

  .bcb__title--{{ sid }} strong {
    font-weight: 700;
  }

  /* Button: [text][icon] */
  .bcb__btn--{{ sid }} {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    flex-shrink: 0;
    cursor: pointer;
  }

  .bcb__btn-text--{{ sid }} {
    display: flex;
    align-items: center;
    padding: 14px 24px;
    background: {{ section.settings.accent_color }};
    color: #111;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    font-family: var(--font-body-family);
    white-space: nowrap;
    transition: border-radius 0.4s cubic-bezier(0.33, 1, 0.68, 1);
  }

  .bcb__btn-icon--{{ sid }} {
    width: 46px;
    min-width: 46px;
    aspect-ratio: 1;
    border-radius: 12px;
    background: {{ section.settings.accent_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-radius 0.4s cubic-bezier(0.33, 1, 0.68, 1);
  }

  .bcb__btn-icon--{{ sid }} svg {
    stroke: #111;
  }

  .bcb__btn--{{ sid }}:hover .bcb__btn-text--{{ sid }} {
    border-radius: 40px;
  }

  .bcb__btn--{{ sid }}:hover .bcb__btn-icon--{{ sid }} {
    border-radius: 50%;
  }

  @media (max-width: 680px) {
    .bcb__inner--{{ sid }} { padding: 0 16px; }
    .bcb__card--{{ sid }} {
      flex-direction: column;
      align-items: flex-start;
      padding: 24px 20px;
      gap: 20px;
    }
  }
</style>

{% schema %}
{
  "name": "Blog CTA Banner",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow label",
      "default": "Get started"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Main text",
      "default": "Start your online business today."
    },
    {
      "type": "text",
      "id": "bold_text",
      "label": "Bold text (appended)",
      "default": "For free."
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Button URL"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Button label",
      "default": "Start for free"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card border",
      "default": "#2a2a2a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#d4ff00"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 480,
      "max": 1200,
      "step": 40,
      "default": 800,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 32,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 16,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Blog CTA Banner"
    }
  ]
}
{% endschema %}
