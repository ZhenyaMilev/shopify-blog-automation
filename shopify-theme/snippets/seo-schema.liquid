      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "App Integration for Shopify"}},
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Performance Optimization"}},
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Conversion & UX Optimization Audit"}},
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Ongoing Support and Maintenance"}},
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Platform Migration to Shopify"}},
      {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Shopify Automation"}}
    ]
  }
}
</script>
{%- endif -%}

